# Spotify API (Required for backend features)
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here

# Frontend URL for CORS (Required for production)
# Set this to your deployed Vercel frontend URL, e.g., https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Port for FastAPI (Railway automatically provides this)
PORT=8000
